{
  "name": "areluna-landing-pages",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:pt": "npm run dev -w @areluna/pt",
    "dev:br": "npm run dev -w @areluna/br",
    "build:pt": "npm run build -w @areluna/pt",
    "build:br": "npm run build -w @areluna/br",
    "build": "npm run build:pt && npm run build:br",
    "lint": "npm run lint --workspaces --if-present"
  }
}
